# Copie este arquivo para .env (raiz) e ajuste se precisar.
# Todas as variáveis têm defaults sensatos no docker-compose; só mexa se necessário.

# --- Postgres ---
POSTGRES_DB=moeda_estudantil
POSTGRES_USER=moeda
POSTGRES_PASSWORD=moeda

# --- CORS (origens permitidas pelo backend) ---
# Prod/demo (nginx em :80):  http://localhost,http://localhost:80
# Dev (Vite em :5173):       http://localhost:5173,http://localhost:5174
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80

# --- Email (SMTP Gmail). Em log-mode se MAIL_ENABLED=false ---
MAIL_ENABLED=false
MAIL_USERNAME=
MAIL_PASSWORD=
